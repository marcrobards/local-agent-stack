# LLM provider for text stages: "ollama" (local) or "claude" (Anthropic API)
LLM_PROVIDER=ollama

# Claude config (only needed when LLM_PROVIDER=claude)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama models (TEXT_MODEL used when LLM_PROVIDER=ollama; VISION always uses Ollama)
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=qwen2.5vl:7b

# Shopping workflow
ANTHROPIC_API_KEY=###
BROWSER_USE_API_KEY=###
BESZEL_TOKEN=###
BESZEL_KEY=###

