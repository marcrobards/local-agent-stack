FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY src/shopping-agent/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    "browser-use>=0.12,<1" \
    langchain-anthropic

# Copy the shopping agent source and the clarify prompt it references
COPY src/shopping-agent/ ./
COPY src/workflows/online-shopping/01-clarify-request/PROMPT.md \
     /app/workflows/01-clarify-request/PROMPT.md

EXPOSE 8000

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]
